rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone authenticated can read (for member lists), only own doc writable
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Groups — only members can read/write
    match /groups/{groupId} {
      allow read:   if request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth.uid in resource.data.members;
      allow delete: if request.auth.uid == resource.data.createdBy;

      // Expenses subcollection — group members only
      match /expenses/{expenseId} {
        allow read, write: if request.auth.uid in
          get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }

      // Settlements subcollection — group members can read, from/to participant can write
      match /settlements/{settlementId} {
        allow read: if request.auth.uid in
          get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if request.auth.uid == request.resource.data.from
                      || request.auth.uid == request.resource.data.to;
      }
    }
  }
}
