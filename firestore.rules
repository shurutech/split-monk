rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone authenticated can read (for member lists), only own doc writable
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Invites — keyed by encoded email.
    // Any auth user can read their own invite doc (needed to resolve on sign-in).
    // Any auth user can write invite docs (needed when creating a group with new emails).
    // The encoded key is email with dots replaced by commas — no sensitive data exposed.
    match /invites/{encodedEmail} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
    }

    // Groups — only members can read/write
    match /groups/{groupId} {
      // Allow read when doc is missing so snapshot listeners get a clean null
      // after deletion instead of a permission-denied error.
      allow read:   if resource == null
                    || request.auth.uid in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth.uid in resource.data.members;
      allow delete: if request.auth.uid == resource.data.createdBy;

      // Expenses subcollection — group members only
      match /expenses/{expenseId} {
        allow read, write: if request.auth.uid in
          get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }

      // Settlements subcollection — any group member can read or record a settlement
      match /settlements/{settlementId} {
        allow read, create: if request.auth.uid in
          get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
