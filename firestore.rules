rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone authenticated can read (for member lists), only own doc writable
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Invites — keyed by encoded email.
    // Any auth user can read their own invite doc (needed to resolve on sign-in).
    // Any auth user can write invite docs (needed when creating a group with new emails).
    // The encoded key is email with dots replaced by commas — no sensitive data exposed.
    match /invites/{encodedEmail} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null;
    }

    // Groups — only members can read/write
    match /groups/{groupId} {
      // Allow read when doc is missing (snapshot after deletion returns clean null).
      // Also allow pending invitees to read — needed so resolvePendingInvites can
      // read the group doc before moving their email into the members array.
      allow read:   if resource == null
                    || request.auth.uid in resource.data.members
                    || (request.auth.token.email != null
                        && request.auth.token.email in resource.data.pendingInvites);
      allow create: if request.auth != null;
      // Also allow pending invitees to update — needed to move email → members on sign-in.
      allow update: if request.auth.uid in resource.data.members
                    || (request.auth.token.email != null
                        && request.auth.token.email in resource.data.pendingInvites);
      allow delete: if request.auth.uid == resource.data.createdBy;

      // Helper: true if the requesting user is a full member or a pending invitee.
      // Pending invitees need read access during the brief window between sign-in
      // and resolvePendingInvites() completing (which moves them into members).
      function isMemberOrPending() {
        let g = get(/databases/$(database)/documents/groups/$(groupId)).data;
        return request.auth.uid in g.members
            || (request.auth.token.email != null
                && request.auth.token.email in g.pendingInvites);
      }

      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read:          if isMemberOrPending();
        // Members can create/update (soft-delete via isDeleted flag) — but NOT hard-delete
        allow create, update: if request.auth.uid in
          get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        // Only the group creator can hard-delete (only used when wiping the whole group)
        allow delete:        if request.auth.uid ==
          get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
      }

      // Settlements subcollection — append-only during normal use; only creator can delete on group wipe
      match /settlements/{settlementId} {
        allow read, create: if isMemberOrPending();
        allow delete:       if request.auth.uid ==
          get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy;
      }
    }
  }
}
